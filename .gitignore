# Large upstream clone (regenerate: git clone --depth 1 https://github.com/rust-lang/rust)
rust/

# Ingestion copies and scratch (regenerate via scrape-rust-docs.sh / .codex-build/scrape-std.sh)
.raw/

# Build logs (kept locally, not part of the repo)
.codex-build/logs/

# Obsidian + desktop local state
.vault-meta/
.obsidian/workspace*.json
.directory

# OS / editor cruft
.DS_Store
Thumbs.db

# Quartz site build artifacts (the published site is built by CI from site/)
site/node_modules/
site/public/
site/.quartz-cache/

# Python cache
__pycache__/
*.pyc

# Example compile-gate build artifacts
scripts/examples-check/target/
